{
  "name": "exceltools",
  "version": "0.1.0",
  "private": true,
  "description": "Offline, browser-based suite of Excel tools running fully client-side (WASM-ready). No data leaves the machine.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "package": "npm run build && node scripts/package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "fflate": "^0.8.2",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.8"
  }
}
